# =============================================================================
# AI GovCon System — Root Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Variables without a default (blank right-hand side) MUST be set before
# running `docker compose up`.  Variables with a default work out of the box
# for local development but should be overridden in staging/production.
# =============================================================================


# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_DB=dealmanager
POSTGRES_USER=dealmanager
POSTGRES_PASSWORD=changeme           # CHANGE in production


# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis URL is composed inside docker-compose; override only if you run Redis
# outside of Docker.
# REDIS_URL=redis://redis:6379/0


# ── MinIO (S3-compatible object storage) ──────────────────────────────────────

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme         # CHANGE in production

# These are used by the Django app / AI orchestrator to talk to MinIO.
# In Docker, MINIO_ENDPOINT is the internal hostname; change to your public
# hostname when accessing from outside the container network.
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin        # same as MINIO_ROOT_USER by default
# MINIO_SECRET_KEY=changeme          # same as MINIO_ROOT_PASSWORD by default
# MINIO_BUCKET=govcon


# ── Django API ────────────────────────────────────────────────────────────────

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=dev-secret-key-change-in-prod   # CHANGE in production

# Comma-separated list of allowed hosts, e.g. yourdomain.com,api.yourdomain.com
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted CSRF origins (protocol + host + port)
CSRF_TRUSTED_ORIGINS=http://localhost:3028,http://127.0.0.1:3028

# Set to true to force HTTPS redirects (production only)
# SECURE_SSL_REDIRECT=false

# JWT signing key (should differ from DJANGO_SECRET_KEY)
JWT_SECRET_KEY=dev-jwt-secret-change-in-prod       # CHANGE in production

# JWT token lifetimes (optional — defaults shown)
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# MFA issuer name shown in authenticator apps
# MFA_ISSUER=AI GovCon System


# ── Django Admin Bootstrap ────────────────────────────────────────────────────

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@dealmanager.local
ADMIN_PASSWORD=Admin1234!            # CHANGE in production


# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Public URLs must be reachable from the user's browser, not just inside Docker.

NEXT_PUBLIC_API_URL=http://localhost:3028/api
NEXT_PUBLIC_WS_URL=ws://localhost:3028/ws


# ── AI / LLM ─────────────────────────────────────────────────────────────────

# Primary LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# Anthropic — required when LLM_PROVIDER=anthropic
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — required when LLM_PROVIDER=openai, or used by some MCP tools
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Voyage AI — used for high-quality embeddings (optional)
# Get your key at https://dash.voyageai.com
VOYAGE_API_KEY=


# ── AI Orchestrator (service-to-service auth) ─────────────────────────────────

# Secret token the AI orchestrator uses to call the Django API internally.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DJANGO_SERVICE_TOKEN=


# ── LLM Observability ────────────────────────────────────────────────────────

# Langfuse — self-hosted instance is included in docker-compose.
# Create a project at http://localhost:3028/langfuse and paste the keys here.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Random hex used by the Langfuse container itself for cookie signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LANGFUSE_SALT=0f6d3e8c9a2b4f7d1a5e9c3b8f2d7a4e6c1b9f3d8e5a2c7f1d4b9e6a3c8f2

# LangSmith — optional, for LangGraph workflow tracing
# Get your key at https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=ai-govcon-system


# ── Government Data APIs ──────────────────────────────────────────────────────

# SAM.gov Opportunities API — required for federal contract scanning.
# Register for a free key at https://sam.gov/content/entity-registration
# (click "Get Started" -> "API Keys" after logging in).
# Without this key the SAM.gov scan task will be skipped with a warning.
SAMGOV_API_KEY=

# Bureau of Labor Statistics — used for wage/market data (optional)
# Register at https://data.bls.gov/registrationEngine/
BLS_API_KEY=


# ── Web Search / Research APIs ───────────────────────────────────────────────
# All optional — enable the research tools you want to use.

# Brave Search API — https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=

# Serper (Google Search proxy) — https://serper.dev/
SERPER_API_KEY=

# Tavily (AI-optimised search) — https://app.tavily.com/
TAVILY_API_KEY=

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=


# ── Email (transactional) ─────────────────────────────────────────────────────
# Leave blank to disable email sending in development.

# SMTP backend (standard)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.com

# SendGrid (alternative to SMTP)
# SENDGRID_API_KEY=
