# =============================================================================
# AI Orchestrator — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...

# Django backend (service-to-service)
DJANGO_API_URL=http://django-api:8001
DJANGO_SERVICE_TOKEN=

# Redis (agent event pub/sub)
REDIS_URL=redis://localhost:6379/0

# ── Langfuse (LLM Observability) ─────────────────────────────────────────────
# Get keys from https://cloud.langfuse.com  or your self-hosted instance.
# Both keys are required.  Remove / leave blank to disable Langfuse.

LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...

# Optional — defaults to Langfuse Cloud.  Override for self-hosted deployments.
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── LangSmith (LangGraph Workflow Tracing) ────────────────────────────────────
# Get your API key from https://smith.langchain.com
# Set LANGCHAIN_TRACING_V2=true to enable.  LangChain/LangGraph will
# automatically trace every graph.ainvoke() call — no code changes needed.

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...

# Optional — groups all runs under this project in LangSmith UI.
LANGCHAIN_PROJECT=ai-govcon-system

# ── OpenAI (optional — used by some MCP tools) ───────────────────────────────
# OPENAI_API_KEY=sk-...
